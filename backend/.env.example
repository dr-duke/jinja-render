# jinja-render backend configuration.
# All variables use the JR_ prefix and map to app/core/config.py:Settings.
# Copy to .env and adjust as needed.

# --- Application ---
JR_app_name=jinja-render
JR_debug=false

# --- Guardrails (sizes in bytes) ---
JR_max_template_bytes=524288
JR_max_data_bytes=1048576
JR_max_data_depth=50

# --- Rendering / persistent worker pool ---
# Workers are started once and reused (no per-request spawn cold-start).
# Per-request wall-clock timeout in seconds. On overrun the worker is killed
# and replaced, and a timeout_error is returned.
JR_render_timeout_seconds=2.0
# Number of persistent worker processes used to run renders.
JR_render_pool_size=2

# --- Rate limiting (in-process, per client key, per-pod in k8s) ---
JR_rate_limit_enabled=true
JR_rate_limit_requests_per_minute=120
JR_rate_limit_burst=40

# --- ansible hostfacts emulation (deterministic; never reads real host facts) ---
JR_ansible_facts_enabled=true
JR_ansible_facts_default=true

# --- API documentation endpoints ---
JR_docs_swagger_path=/swagger
JR_openapi_url=/openapi.json

# --- Static frontend serving (single-container packaging) ---
# Directory FastAPI serves the built SPA from. The image copies the Vite build
# (frontend/dist) here. Leave the default unless you mount the SPA elsewhere.
JR_static_dir=/app/static
# Optional runtime CSS override file served at /custom.css. Empty means
# <JR_static_dir>/custom.css. Mount a file here (e.g. a k8s ConfigMap) to
# restyle without rebuilding; absent file yields an empty no-op stylesheet.
JR_custom_css_path=

# --- CORS (JSON array) ---
JR_cors_origins=["http://localhost:5173","http://127.0.0.1:5173"]
