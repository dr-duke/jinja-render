# Backend configuration (prefix JR_). Copy to .env and adjust as needed.
# The single app container serves the API + built SPA on one origin (port 8000).
JR_DEBUG=false
JR_RENDER_TIMEOUT_SECONDS=2.0
JR_MAX_TEMPLATE_BYTES=524288
JR_MAX_DATA_BYTES=1048576
JR_MAX_DATA_DEPTH=50
# Directory FastAPI serves the built SPA from (the image copies dist here).
# JR_STATIC_DIR=/app/static
# Optional runtime CSS override file (empty = <static_dir>/custom.css).
# JR_CUSTOM_CSS_PATH=
# Comma/JSON list of allowed CORS origins for local dev.
# JR_CORS_ORIGINS=["http://localhost:5173"]
